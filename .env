# Configuración de la base de datos
# Copia este archivo a .env y actualiza los valores según tu configuración

# Host de la base de datos (default: localhost)
DB_HOST=localhost

# Usuario de la base de datos (default: root)
DB_USER=root

# Contraseña de la base de datos (default: "")
DB_PASSWORD=

# Nombre de la base de datos (default: hospedaje)
DB_NAME=hospedaje

# Puerto del servidor (opcional, default: 3000)
PORT=3000

# Entorno de ejecución (development, production)
NODE_ENV=development

# Origen permitido para CORS (para producción, cambiar a la URL del frontend)
CORS_ORIGIN=http://localhost:5500
